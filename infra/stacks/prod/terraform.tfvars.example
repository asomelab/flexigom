# Copy to terraform.tfvars and set real values. terraform.tfvars is gitignored.

# No custom domain to start — uses the CloudFront default URL (*.cloudfront.net).
# Uncomment and set when ready to add the real domain:
# domain_aliases = ["flexigomtucuman.com", "www.flexigomtucuman.com"]
domain_aliases = []

