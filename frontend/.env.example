VITE_STRAPI_URL=<strapi_url>
VITE_API_BASE_URL=<api_url>
VITE_NODE_ENV=<mode>

# MercadoPago webhook URL (publicly accessible backend URL)
# In development with ngrok: https://your-ngrok-url.ngrok-free.app/api/mercadopago/webhook
# In production: https://your-production-domain.com/api/mercadopago/webhook
VITE_MERCADOPAGO_WEBHOOK_URL=<webhook_url>

# Sentry error tracking (optional — leave empty to disable)
# Create a free React project at sentry.io, then: pnpm add @sentry/react
# Set this in the Flexigom / prod GitHub Environment as a secret env var at build time.
VITE_SENTRY_DSN=